STACK=production
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
JWT_SECRET=REPLACE_WITH_A_STRONG_64_CHAR_RANDOM_SECRET
ALLOWED_ORIGIN=https://your-frontend.onrender.com
# One-time secret to create the first superadmin (set in Render dashboard, remove after first use)
SUPERADMIN_SETUP_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
